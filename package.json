{
  "name": "doyoudj-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "security:audit": "pnpm audit --audit-level moderate",
    "security:fix": "pnpm audit --fix",
    "deps:update": "pnpm update",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "mcp:import": "node scripts/add-mcp-config-to-mongodb.js",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .next out dist",
    "docker:build": "docker build -t doyoudj-app .",
    "docker:dev": "docker-compose up -d",
    "cleanup": "chmod +x scripts/workflow-complete.sh && ./scripts/workflow-complete.sh"
  },
  "dependencies": {
    "@clerk/express": "^1.7.5",
    "@clerk/nextjs": "^6.24.0",
